{
  "version": 3,
  "configurePresets": [
    {
      "name": "llvm",
      "displayName": "LLVM Clang 20",
      "description": "Configure with LLVM Clang 20.1.8",
      "toolchainFile": ".cmake/llvm-toolchain.cmake",
      "binaryDir": "cmake-build-llvm",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "ZWAVED_EXTERNAL_API": "dbus",
        "ZWAVED_LOGGER_SINK": "stdout",
        "ZWAVED_BUILD_UTILS": "ON"
      }
    },
    {
      "name": "gnu",
      "displayName": "GNU GCC 15",
      "description": "Configure with GNU GCC 15.2.0",
      "toolchainFile": ".cmake/gnu-toolchain.cmake",
      "binaryDir": "cmake-build-gnu",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "ZWAVED_EXTERNAL_API": "dbus",
        "ZWAVED_LOGGER_SINK": "stdout",
        "ZWAVED_BUILD_UTILS": "ON"
      }
    },
    {
      "name": "llvm-tidy",
      "displayName": "LLVM Clang 20 + clang-tidy",
      "description": "Configure with LLVM Clang 20.1.8 and clang-tidy analysis during build",
      "inherits": "llvm",
      "binaryDir": "cmake-build-llvm-tidy",
      "cacheVariables": {
        "CMAKE_CXX_CLANG_TIDY": "clang-tidy"
      }
    },
    {
      "name": "gnu-tidy",
      "displayName": "GNU GCC 15 + clang-tidy",
      "description": "Configure with GNU GCC 15.2.0 and clang-tidy analysis during build",
      "inherits": "gnu",
      "binaryDir": "cmake-build-gnu-tidy",
      "cacheVariables": {
        "CMAKE_CXX_CLANG_TIDY": "clang-tidy"
      }
    }
  ]
}
