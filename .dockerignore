# Keep the docker build context small and reproducible. The build
# stage runs `cmake --preset gnu` itself, so out-of-tree build
# directories from the host machine are never useful — and shipping
# them inflates the context by hundreds of MB.

# CMake out-of-tree build trees.
cmake-build-*/

# Editor / IDE droppings.
.idea/
.vscode/
.cache/
*.swp
*.swo

# Generated by the local pre-commit / scripts/check-format runs.
.clang-tidy.cache

# Git internals — needed only for the `git describe` step at configure
# time, which the Dockerfile doesn't rely on (PROJECT_VERSION comes
# from CMakeLists.txt; missing .git just yields GIT_DESCRIBE="unknown").
# If you want git-describe to work inside the container, comment the
# next line out.
# .git/

# Docker / CI artifacts.
.dockerignore
Dockerfile
.github/
